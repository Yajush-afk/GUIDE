{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guide.local/schemas/lesson.schema.json",
  "title": "GUIDE Lesson",
  "type": "object",
  "required": ["id", "title", "platform", "version", "steps"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "title": {
      "type": "string"
    },
    "platform": {
      "type": "string",
      "const": "windows"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "instruction", "validation"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          },
          "instruction": {
            "type": "string"
          },
          "voice_text": {
            "type": "string"
          },
          "target": {
            "type": "object",
            "additionalProperties": true
          },
          "validation": {
            "type": "object",
            "required": ["strategy"],
            "properties": {
              "strategy": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "hints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
